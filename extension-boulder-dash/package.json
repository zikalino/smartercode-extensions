{
  "name": "extension-boulder-dash",
  "displayName": "Boulder Dash Webview",
  "description": "A Boulder Dash-style puzzle arcade game inside a VS Code webview.",
  "version": "0.0.1",
  "publisher": "local-dev",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "boulderDashGame.open",
        "title": "Open Boulder Dash Game",
        "category": "Boulder Dash"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -b",
    "watch": "tsc -b -w"
  },
  "dependencies": {
    "@upcloud/common": "0.0.1"
  }
}
