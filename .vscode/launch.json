{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Example Extension",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/extension-example"
      ],
      "outFiles": [
        "${workspaceFolder}/extension-example/out/**/*.js"
      ],
      "preLaunchTask": "npm: watch"
    },
    {
      "name": "Run Docker Runner Extension",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/extension-docker-runner"
      ],
      "outFiles": [
        "${workspaceFolder}/extension-docker-runner/out/**/*.js"
      ],
      "preLaunchTask": "npm: watch"
    },
    {
      "name": "Run Git Slice Extension",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/extension-git-slice"
      ],
      "outFiles": [
        "${workspaceFolder}/extension-git-slice/out/**/*.js"
      ],
      "preLaunchTask": "npm: watch"
    }
  ]
}
