{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run UpCloud Extension",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/extension-map-designer"
      ],
      "outFiles": [
        "${workspaceFolder}/extension-map-designer/out/**/*.js"
      ],
      "preLaunchTask": "npm: watch"
    },
    {
      "name": "Run Example Extension",
