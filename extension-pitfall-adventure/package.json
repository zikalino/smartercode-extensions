{
  "name": "extension-pitfall-adventure",
  "displayName": "Pitfall Adventure",
  "description": "A retro Pitfall II-style jungle adventure game in a VS Code webview.",
  "version": "0.0.1",
  "publisher": "local-dev",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "pitfallAdventureGame.open",
        "title": "Open Pitfall Adventure",
        "category": "Pitfall Adventure"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -b",
    "watch": "tsc -b -w"
  },
  "dependencies": {
    "@upcloud/common": "0.0.1"
  }
}
